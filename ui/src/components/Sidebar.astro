---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navItems = [
  { href: '/', label: 'Chat', icon: 'chat' },
  { href: '/dashboard', label: 'Dashboard', icon: 'dashboard' },
  { href: '/decisions', label: 'Decisions', icon: 'decisions' },
  { href: '/monitoring', label: 'Health Checks', icon: 'health' },
];
---

<aside
  id="sidebar"
  class="fixed inset-y-0 left-0 z-40 flex w-60 flex-col border-r border-[var(--color-border)] bg-[var(--color-bg)] transition-transform duration-200 -translate-x-full max-md:[html.sidebar-open_&]:translate-x-0 md:translate-x-0"
  aria-label="Main navigation"
>
  <!-- Logo / Brand -->
  <div class="flex h-14 items-center gap-2 border-b border-[var(--color-border)] px-5">
    <span class="flex h-7 w-7 items-center justify-center rounded-md bg-[var(--color-primary)] text-xs font-bold text-white" aria-hidden="true">FW</span>
    <span class="text-sm font-semibold text-[var(--color-text)]">FW Agent</span>
  </div>

  <!-- Navigation Links -->
  <nav class="flex-1 space-y-1 px-3 py-4">
    {navItems.map((item) => {
      // Normalize paths: handle trailing slashes and root paths
      const normalizeRoute = (path: string) => path === '/' ? '/' : path.replace(/\/$/, '');
      const isActive = normalizeRoute(currentPath) === normalizeRoute(item.href);
      return (
        <a
          href={item.href}
          class={`
            flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-colors duration-150
            ${isActive
              ? 'bg-[var(--color-primary-subtle)] text-[var(--color-primary)]'
              : 'text-[var(--color-text-secondary)] hover:bg-[var(--color-surface-elevated)] hover:text-[var(--color-text)]'
            }
          `}
          aria-current={isActive ? 'page' : undefined}
        >
          <!-- Icon -->
          <span class="flex h-5 w-5 shrink-0 items-center justify-center" aria-hidden="true">
            {item.icon === 'chat' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            )}
            {item.icon === 'dashboard' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7"/>
                <rect x="14" y="3" width="7" height="7"/>
                <rect x="3" y="14" width="7" height="7"/>
                <rect x="14" y="14" width="7" height="7"/>
              </svg>
            )}
            {item.icon === 'decisions' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 11 12 14 22 4"/>
                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
              </svg>
            )}
            {item.icon === 'health' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
              </svg>
            )}
          </span>
          {item.label}
        </a>
      );
    })}
  </nav>

  <!-- Footer -->
  <div class="border-t border-[var(--color-border)] px-5 py-3">
    <span class="text-xs text-[var(--color-text-muted)]">AI Agent Dashboard</span>
  </div>
</aside>

---
---

<div class="settings-panel">
	<style>
		.settings-panel {
			background: #1a1f3a;
			border-bottom: 1px solid #374151;
			overflow: hidden;
			transition: max-height 0.3s ease;
		}

		.settings-panel.collapsed {
			max-height: 0;
		}

		.settings-header {
			padding: 1rem 1.5rem;
			display: flex;
			align-items: center;
			gap: 0.75rem;
			cursor: pointer;
			user-select: none;
		}

		.settings-header:hover {
			background: #253355;
		}

		.settings-toggle {
			display: inline-block;
			width: 20px;
			height: 20px;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 0.75rem;
			transition: transform 0.3s;
		}

		.settings-panel.collapsed .settings-toggle {
			transform: rotate(-90deg);
		}

		.settings-content {
			padding: 0 1.5rem 1rem;
			display: flex;
			gap: 2rem;
			flex-wrap: wrap;
		}

		.settings-group {
			flex: 1;
			min-width: 200px;
		}

		.settings-label {
			display: block;
			font-size: 0.875rem;
			font-weight: 600;
			margin-bottom: 0.5rem;
			color: #f3f4f6;
		}

		.settings-value {
			display: inline-block;
			font-size: 0.8rem;
			background: #2563eb;
			color: white;
			padding: 0.2rem 0.6rem;
			border-radius: 3px;
			margin-left: 0.5rem;
		}

		input[type='range'] {
			width: 100%;
			height: 6px;
			border-radius: 3px;
			background: #374151;
			outline: none;
			-webkit-appearance: none;
			appearance: none;
		}

		input[type='range']::-webkit-slider-thumb {
			-webkit-appearance: none;
			appearance: none;
			width: 16px;
			height: 16px;
			border-radius: 50%;
			background: #2563eb;
			cursor: pointer;
			transition: background 0.2s;
		}

		input[type='range']::-webkit-slider-thumb:hover {
			background: #1d4ed8;
		}

		input[type='range']::-moz-range-thumb {
			width: 16px;
			height: 16px;
			border-radius: 50%;
			background: #2563eb;
			cursor: pointer;
			border: none;
			transition: background 0.2s;
		}

		input[type='range']::-moz-range-thumb:hover {
			background: #1d4ed8;
		}

		.checkbox-group {
			display: flex;
			align-items: center;
			gap: 0.75rem;
		}

		input[type='checkbox'] {
			width: 18px;
			height: 18px;
			cursor: pointer;
		}

		@media (max-width: 768px) {
			.settings-content {
				gap: 1rem;
				flex-direction: column;
			}

			.settings-group {
				min-width: 100%;
			}

			.settings-header {
				padding: 0.75rem 1rem;
			}

			.settings-content {
				padding: 0 1rem 1rem;
			}
		}
	</style>

	<div class="settings-header" id="settingsHeader">
		<span class="settings-toggle">▶</span>
		<span>Settings</span>
	</div>

	<div class="settings-content collapsed" id="settingsContent">
		<div class="settings-group">
			<label class="settings-label">
				Top-K Results
				<span class="settings-value" id="topKValue">5</span>
			</label>
			<input
				type="range"
				id="topKSlider"
				min="1"
				max="20"
				value="5"
				step="1"
			/>
		</div>

		<div class="settings-group">
			<label class="settings-label">
				Temperature
				<span class="settings-value" id="tempValue">0.7</span>
			</label>
			<input
				type="range"
				id="tempSlider"
				min="0"
				max="1"
				value="0.7"
				step="0.1"
			/>
		</div>

		<div class="settings-group checkbox-group">
			<input type="checkbox" id="includeSourcesCheckbox" checked />
			<label for="includeSourcesCheckbox" class="settings-label"
				>Include Sources</label
			>
		</div>
	</div>
</div>

<script>
	const settingsPanel = document.querySelector('.settings-panel');
	const settingsHeader = document.getElementById('settingsHeader');
	const settingsContent = document.getElementById('settingsContent');
	const topKSlider = document.getElementById('topKSlider') as HTMLInputElement;
	const topKValue = document.getElementById('topKValue');
	const tempSlider = document.getElementById('tempSlider') as HTMLInputElement;
	const tempValue = document.getElementById('tempValue');
	const includeSourcesCheckbox = document.getElementById(
		'includeSourcesCheckbox'
	) as HTMLInputElement;

	// Toggle settings panel
	if (settingsHeader) {
		settingsHeader.addEventListener('click', () => {
			settingsPanel?.classList.toggle('collapsed');
			if (settingsContent?.classList.contains('collapsed')) {
				settingsContent.classList.remove('collapsed');
			} else {
				settingsContent?.classList.add('collapsed');
			}
		});
	}

	// Handle slider changes
	if (topKSlider) {
		topKSlider.addEventListener('input', (e) => {
			const value = (e.target as HTMLInputElement).value;
			if (topKValue) topKValue.textContent = value;
			(window as any).updateSettings?.('topK', parseInt(value));
		});
	}

	if (tempSlider) {
		tempSlider.addEventListener('input', (e) => {
			const value = (e.target as HTMLInputElement).value;
			if (tempValue) tempValue.textContent = parseFloat(value).toFixed(1);
			(window as any).updateSettings?.('temperature', parseFloat(value));
		});
	}

	if (includeSourcesCheckbox) {
		includeSourcesCheckbox.addEventListener('change', (e) => {
			(window as any).updateSettings?.(
				'includeSources',
				(e.target as HTMLInputElement).checked
			);
		});
	}

	// Load settings on init
	window.addEventListener('load', () => {
		const state = (window as any).state;
		if (state && state.settings) {
			if (topKSlider) {
				topKSlider.value = state.settings.topK;
				if (topKValue) topKValue.textContent = state.settings.topK;
			}
			if (tempSlider) {
				tempSlider.value = state.settings.temperature;
				if (tempValue)
					tempValue.textContent =
						state.settings.temperature.toFixed(1);
			}
			if (includeSourcesCheckbox) {
				includeSourcesCheckbox.checked = state.settings.includeSources;
			}
		}
	});
</script>

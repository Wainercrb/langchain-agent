---
// ChatContainer - Professional Tailwind CSS chat UI
---

<div class="flex flex-col h-screen w-full bg-[#f9f9ff] text-[#111c2d]">
	<!-- Header -->
	<div class="flex items-center justify-between px-6 py-4 border-b border-[#c7c4d7] bg-[#f9f9ff] shadow-sm">
		<div class="flex items-center gap-3">
			<div>
				<h1 class="text-xl font-bold text-[#111c2d]">FW Agent</h1>
				<p class="text-xs text-gray-500 flex items-center gap-1">
					<span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
					System Online
				</p>
			</div>
		</div>
		<div class="flex items-center gap-2 px-3 py-1 bg-green-100 border border-green-300 rounded-full" data-status-badge="true">
			<div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
			<span class="text-xs font-medium text-green-700">Online</span>
		</div>
	</div>

	<!-- Messages Area -->
	<div class="flex-1 overflow-y-auto px-6 py-6 space-y-4 bg-[#f9f9ff]">
		<div class="flex flex-col items-center justify-center h-full text-center opacity-50 pointer-events-none">
			<div class="text-4xl mb-2">💭</div>
			<p class="text-[#626567]">Start a conversation...</p>
			<p class="text-xs text-[#626567] mt-1">Ask anything about the documents</p>
		</div>
	</div>

	<!-- Input Section with Inline Settings -->
	<div class="px-6 py-4 border-t border-[#c7c4d7] bg-[#f9f9ff]">
		<!-- Main Input Card -->
		<div class="relative bg-white border border-[#c7c4d7] rounded-2xl overflow-hidden focus-within:border-[#6366f1] focus-within:ring-2 focus-within:ring-[#6366f1]/20 transition shadow-sm hover:shadow-md">
			<!-- Textarea with paperclip icon -->
			<div class="relative px-5 pt-4 pb-2">
				<!-- Paperclip icon -->
				<div class="absolute left-5 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none z-10">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18.84 5.6l-8.58 8.58a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
				</div>
				<textarea
					placeholder="Ask anything about the documents..."
					rows="2"
					class="w-full pl-8 pr-4 py-2 bg-white text-[#111c2d] rounded-2xl focus:outline-none resize-none font-inherit text-base transition placeholder-gray-400"
				></textarea>
			</div>

			<!-- Bottom Section: Controls on Left, Button on Right -->
			<div class="flex items-center justify-between px-5 py-3 bg-white border-t border-gray-200">
				<!-- Settings Controls -->
				<div class="flex items-center justify-start gap-6">
					<!-- Results (K) Toggle -->
					<div class="flex items-center gap-2">
						<label class="relative inline-flex items-center cursor-pointer">
							<input type="checkbox" id="resultsToggle" class="sr-only peer results-toggle" />
							<div class="w-8 h-4 bg-gray-300 rounded-full peer-checked:bg-indigo-500 transition peer-focus:ring-2 peer-focus:ring-indigo-500/30"></div>
							<div class="absolute left-0.5 top-0.5 w-3 h-3 bg-white rounded-full transition peer-checked:translate-x-4"></div>
						</label>
						<span class="text-xs font-medium text-gray-600 whitespace-nowrap">Results (K)</span>
					</div>

					<!-- Creativity Toggle -->
					<div class="flex items-center gap-2">
						<label class="relative inline-flex items-center cursor-pointer">
							<input type="checkbox" id="creativityToggle" class="sr-only peer creativity-toggle" />
							<div class="w-8 h-4 bg-gray-300 rounded-full peer-checked:bg-indigo-500 transition peer-focus:ring-2 peer-focus:ring-indigo-500/30"></div>
							<div class="absolute left-0.5 top-0.5 w-3 h-3 bg-white rounded-full transition peer-checked:translate-x-4"></div>
						</label>
						<span class="text-xs font-medium text-gray-600 whitespace-nowrap">Creativity</span>
					</div>

					<!-- Show Sources Checkbox -->
					<label class="flex items-center gap-2 cursor-pointer">
						<input type="checkbox" id="includeSources" name="includeSources" checked class="w-3.5 h-3.5 cursor-pointer accent-indigo-600 rounded" />
						<span class="text-xs font-medium text-gray-600 whitespace-nowrap">Show Sources</span>
					</label>
				</div>

				<!-- Send Button -->
				<button
					type="button"
					aria-label="Send message"
					class="w-9 h-9 flex items-center justify-center rounded-full bg-[#6366f1] text-white transition-all hover:bg-[#4648d4] disabled:opacity-50 disabled:cursor-not-allowed shadow-lg hover:shadow-xl ml-4 flex-shrink-0"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>
				</button>
			</div>
		</div>

		<!-- Hint text and disclaimer -->
		<div class="text-xs text-gray-400 mt-2 px-1 flex flex-col items-center">
			<span class="hidden sm:inline">Shift + Enter for new line</span>
			<p class="text-xs text-gray-400 text-center mt-3">FW Agent may provide inaccurate information. Verify critical data.</p>
		</div>
	</div>

	<!-- Hidden sliders for actual values -->
	<div class="hidden">
		<input
			type="range"
			id="topK"
			name="topK"
			min="1"
			max="20"
			value="5"
			class="topk-slider"
		/>
		<input
			type="range"
			id="temperature"
			name="temperature"
			min="0"
			max="1"
			step="0.1"
			value="0.7"
			class="temperature-slider"
		/>
	</div>
</div>

<script>
	// Results toggle
	const topKInput = document.querySelector('input[name="topK"]') as HTMLInputElement;
	const resultsToggle = document.getElementById('resultsToggle') as HTMLInputElement;
	
	if (topKInput && resultsToggle) {
		resultsToggle.addEventListener('change', () => {
			topKInput.value = resultsToggle.checked ? '10' : '5';
		});
	}

	// Creativity toggle
	const tempInput = document.querySelector('input[name="temperature"]') as HTMLInputElement;
	const creativityToggle = document.getElementById('creativityToggle') as HTMLInputElement;
	
	if (tempInput && creativityToggle) {
		creativityToggle.addEventListener('change', () => {
			tempInput.value = creativityToggle.checked ? '0.9' : '0.7';
		});
	}

	// Auto-expand textarea
	const textarea = document.querySelector('textarea') as HTMLTextAreaElement;
	if (textarea) {
		textarea.addEventListener('input', () => {
			textarea.style.height = 'auto';
			textarea.style.height = Math.min(textarea.scrollHeight, 96) + 'px';
		});

		// Handle Shift+Enter for new line, Enter to send
		textarea.addEventListener('keydown', (e: KeyboardEvent) => {
			if (e.key === 'Enter' && !e.shiftKey) {
				e.preventDefault();
				const sendBtn = document.querySelector('button[aria-label="Send message"]') as HTMLButtonElement;
				if (sendBtn) sendBtn.click();
			}
		});
	}
</script>

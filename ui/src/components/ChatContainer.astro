---
// ChatContainer — Main chat layout shell (Tailwind CSS only)
---

<div class="fixed inset-0 md:left-64 top-14 z-10 flex flex-col bg-[var(--color-bg)]">
  <!-- Chat messages area -->
  <div class="flex-1 w-full overflow-y-auto min-h-0">
    <div class="max-w-4xl mx-auto px-4 pt-4 h-full">
      <section class="h-full" aria-label="Chat messages">
        <slot />
      </section>
    </div>
  </div>

  <!-- Bottom Input -->
  <div class="shrink-0 w-full bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto px-4 pb-4 pt-2">
      <div class="flex flex-col gap-3 bg-white/70 border border-[var(--color-border)] rounded-[var(--radius-lg)] p-3 shadow-[var(--shadow-xl)] backdrop-blur-md transition-[border-color,box-shadow] duration-150 focus-within:border-[var(--color-border-focus)]">
        <!-- Textarea -->
        <textarea
          id="chat-input"
          class="w-full border-none bg-transparent text-[var(--color-text)] text-base leading-[1.625] resize-none py-2 min-h-[1.5rem] max-h-[6rem] focus:outline-none placeholder:text-[var(--color-text-muted)]"
          placeholder="Message FW Agent..."
          rows="1"
          aria-label="Type your message"></textarea>

        <!-- Actions Row -->
        <div class="flex items-center justify-between pt-2 border-t border-[rgba(199,196,215,0.5)] gap-4">
          <div class="flex items-center gap-4 flex-wrap">
            <!-- Results (K) — editable badge -->
            <div class="flex items-center gap-2" aria-label="Results (K)">
              <input
                type="number"
                id="results-badge"
                min="1"
                max="20"
                class="flex items-center justify-center min-w-[2rem] h-6 px-1 bg-[rgba(70,72,212,0.1)] text-[var(--color-primary)] text-xs font-bold rounded-[var(--radius-sm)] border-none text-center focus:outline-none appearance-none [&::-webkit-inner-spin-button]:hidden [&::-webkit-outer-spin-button]:hidden"
                aria-label="Edit Results (K)"
              />
              <span class="text-[11px] font-semibold tracking-widest text-[var(--color-text-secondary)] whitespace-nowrap">Results (K)</span>
            </div>

            <!-- Creativity — editable badge -->
            <div class="flex items-center gap-2" aria-label="Creativity">
              <input
                type="number"
                id="creativity-badge"
                min="0"
                max="1"
                step="0.1"
                class="flex items-center justify-center min-w-[2rem] h-6 px-1 bg-[rgba(70,72,212,0.1)] text-[var(--color-primary)] text-xs font-bold rounded-[var(--radius-sm)] border-none text-center focus:outline-none appearance-none [&::-webkit-inner-spin-button]:hidden [&::-webkit-outer-spin-button]:hidden"
                aria-label="Edit Creativity"
              />
              <span class="text-[11px] font-semibold tracking-widest text-[var(--color-text-secondary)] whitespace-nowrap">Creativity</span>
            </div>

            <!-- Show Sources — checkbox -->
            <label class="flex items-center gap-2 cursor-pointer" aria-label="Show Sources">
              <div class="relative flex items-center">
                <input type="checkbox" id="include-sources" checked class="peer sr-only" />
                <span class="w-3.5 h-3.5 border border-[var(--color-border)] rounded bg-[var(--color-surface)] peer-checked:bg-[var(--color-primary)] peer-checked:border-[var(--color-primary)] peer-focus-visible:ring-2 peer-focus-visible:ring-[var(--color-border-focus)] peer-focus-visible:ring-offset-2 transition-colors duration-150" aria-hidden="true"></span>
                <svg class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-2.5 h-2.5 text-white opacity-0 peer-checked:opacity-100 transition-opacity pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <span class="text-[11px] font-semibold tracking-widest text-[var(--color-text-secondary)] whitespace-nowrap">Show Sources</span>
            </label>
          </div>

          <!-- Send button -->
          <button
            type="button"
            id="send-btn"
            class="flex items-center justify-center p-3 bg-[var(--color-primary)] text-white border-none rounded-[var(--radius-md)] cursor-pointer shadow-[var(--shadow-md)] transition-all duration-150 shrink-0 hover:bg-[var(--color-primary-hover)] active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed focus-visible:ring-2 focus-visible:ring-[var(--color-border-focus)] focus-visible:ring-offset-2"
            aria-label="Send message"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M12 19V5"></path>
              <path d="m5 12 7-7 7 7"></path>
            </svg>
          </button>
        </div>
      </div>

      <!-- Disclaimer -->
      <p class="mt-3 text-[11px] font-semibold tracking-widest text-[var(--color-text-secondary)] opacity-60 text-center">
        FW Agent may provide inaccurate information. Verify critical data.
      </p>
    </div>
  </div>
</div>

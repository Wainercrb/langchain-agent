---
// ChatContainer — Main chat layout shell
---

<div class="chat-container">
  <!-- Header -->
  <header class="chat-header">
    <div class="chat-header__brand">
      <h1 class="chat-header__title">FW Agent</h1>
      <p class="chat-header__status">
        <span class="status-dot status-dot--online" id="status-dot" aria-hidden="true"></span>
        <span class="status-text status-text--online" id="status-text">System Online</span>
      </p>
    </div>
  </header>

  <!-- Main content area -->
  <main class="chat-main" role="main">
    <section class="chat-messages-area" aria-label="Chat messages">
      <!-- Messages rendered by ChatIsland -->
      <slot />
    </section>
  </main>

  <!-- Input Section -->
  <footer class="chat-input-section" role="contentinfo">
    <form class="chat-input-form" onsubmit="return false;">
      <!-- Input card -->
      <div class="chat-input-card">
        <!-- Textarea with paperclip -->
        <div class="chat-input-wrapper">
          <!-- Paperclip icon (decorative) -->
          <span class="chat-input-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18.84 5.6l-8.58 8.58a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
            </svg>
          </span>
          <textarea
            id="chat-input"
            class="chat-textarea"
            placeholder="Ask anything about the documents..."
            rows="2"
            aria-label="Type your message"
          ></textarea>
        </div>

        <!-- Bottom row: settings + send -->
        <div class="chat-input-footer">
          <!-- Settings controls -->
          <div class="chat-settings">
            <!-- Results (K) Toggle -->
            <label class="chat-toggle" aria-label="Results (K)">
              <input type="checkbox" id="results-toggle" class="sr-only" />
              <span class="chat-toggle__track">
                <span class="chat-toggle__thumb"></span>
              </span>
              <span class="chat-toggle__label">Results (K)</span>
            </label>

            <!-- Creativity Toggle -->
            <label class="chat-toggle" aria-label="Creativity">
              <input type="checkbox" id="creativity-toggle" class="sr-only" />
              <span class="chat-toggle__track">
                <span class="chat-toggle__thumb"></span>
              </span>
              <span class="chat-toggle__label">Creativity</span>
            </label>

            <!-- Show Sources -->
            <label class="chat-checkbox" aria-label="Show sources">
              <input type="checkbox" id="include-sources" checked />
              <span class="chat-checkbox__box" aria-hidden="true"></span>
              <span class="chat-checkbox__label">Show Sources</span>
            </label>
          </div>

          <!-- Send button -->
          <button
            type="button"
            id="send-btn"
            class="chat-send-btn"
            aria-label="Send message"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m5 12 7-7 7 7"/>
              <path d="M12 19V5"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Hint text -->
      <p class="chat-hint">Shift + Enter for new line</p>

      <!-- Disclaimer -->
      <p class="chat-disclaimer">FW Agent may provide inaccurate information. Verify critical data.</p>
    </form>
  </footer>
</div>

<style>
  /* ============================================
     Layout
     ============================================ */
  .chat-container {
    display: flex;
    flex-direction: column;
    height: 100vh;
    width: 100%;
    background: var(--color-bg);
    color: var(--color-text);
  }

  /* ============================================
     Header
     ============================================ */
  .chat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-6);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .chat-header__brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .chat-header__title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }

  .chat-header__status {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* ============================================
     Main Content
     ============================================ */
  .chat-main {
    flex: 1;
    overflow: hidden;
  }

  .chat-messages-area {
    height: 100%;
    background: var(--color-bg);
  }

  /* ============================================
     Input Section
     ============================================ */
  .chat-input-section {
    padding: var(--space-4) var(--space-6);
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .chat-input-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .chat-input-card:focus-within {
    border-color: var(--color-border-focus);
    box-shadow: 0 0 0 3px var(--color-primary-subtle);
  }

  /* Input wrapper */
  .chat-input-wrapper {
    position: relative;
    padding: var(--space-3) var(--space-4);
  }

  .chat-input-icon {
    position: absolute;
    left: var(--space-4);
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
  }

  .chat-textarea {
    width: 100%;
    padding: var(--space-2) var(--space-4) var(--space-2) var(--space-8);
    border: none;
    background: transparent;
    color: var(--color-text);
    font-family: inherit;
    font-size: 1rem;
    line-height: 1.5;
    resize: none;
  }

  .chat-textarea:focus {
    outline: none;
  }

  .chat-textarea::placeholder {
    color: var(--color-text-muted);
  }

  /* Input footer */
  .chat-input-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  /* ============================================
     Settings Controls
     ============================================ */
  .chat-settings {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  /* Toggle switch */
  .chat-toggle {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    cursor: pointer;
  }

  .chat-toggle__track {
    position: relative;
    width: 2rem;
    height: 1rem;
    background: var(--color-border);
    border-radius: var(--radius-full);
    transition: background var(--transition-fast);
  }

  .chat-toggle input:checked + .chat-toggle__track {
    background: var(--color-primary);
  }

  .chat-toggle__thumb {
    position: absolute;
    left: 2px;
    top: 2px;
    width: 0.75rem;
    height: 0.75rem;
    background: white;
    border-radius: 50%;
    transition: transform var(--transition-fast);
  }

  .chat-toggle input:checked + .chat-toggle__track .chat-toggle__thumb {
    transform: translateX(1rem);
  }

  .chat-toggle input:focus-visible + .chat-toggle__track {
    outline: 2px solid var(--color-border-focus);
    outline-offset: 2px;
  }

  .chat-toggle__label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  /* Checkbox */
  .chat-checkbox {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    cursor: pointer;
  }

  .chat-checkbox input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .chat-checkbox__box {
    width: 0.875rem;
    height: 0.875rem;
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    background: var(--color-surface);
    transition: background var(--transition-fast), border-color var(--transition-fast);
  }

  .chat-checkbox input:checked + .chat-checkbox__box {
    background: var(--color-primary);
    border-color: var(--color-primary);
  }

  .chat-checkbox input:checked + .chat-checkbox__box::after {
    content: '';
    display: block;
    width: 5px;
    height: 9px;
    margin: 1px auto;
    border: solid white;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }

  .chat-checkbox input:focus-visible + .chat-checkbox__box {
    outline: 2px solid var(--color-border-focus);
    outline-offset: 2px;
  }

  .chat-checkbox__label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  /* ============================================
     Send Button
     ============================================ */
  .chat-send-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    background: var(--color-primary);
    color: white;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    transition: background var(--transition-fast), box-shadow var(--transition-fast);
    flex-shrink: 0;
  }

  .chat-send-btn:hover:not(:disabled) {
    background: var(--color-primary-hover);
    box-shadow: var(--shadow-lg);
  }

  .chat-send-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .chat-send-btn:focus-visible {
    outline: 2px solid var(--color-border-focus);
    outline-offset: 2px;
  }

  /* ============================================
     Hint & Disclaimer
     ============================================ */
  .chat-hint {
    margin-top: var(--space-2);
    padding-left: var(--space-1);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .chat-disclaimer {
    margin-top: var(--space-2);
    text-align: center;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  /* ============================================
     Status
     ============================================ */
  .status-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: var(--radius-full);
  }

  .status-dot--online {
    background: var(--color-success);
    animation: pulse-soft 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  .status-dot--offline {
    background: var(--color-error);
    animation: none;
  }

  .status-text {
    font-size: 0.75rem;
    font-weight: 500;
  }

  .status-text--online {
    color: var(--color-text-secondary);
  }

  .status-text--offline {
    color: var(--color-error);
  }

  @keyframes pulse-soft {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }
</style>

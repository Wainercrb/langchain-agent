<div class="message">
	<style>
		.message {
			display: flex;
			margin-bottom: 1rem;
		}

		.message.user-message {
			justify-content: flex-end;
		}

		.message-bubble {
			max-width: 80%;
			padding: 0.75rem 1rem;
			border-radius: 12px;
			word-wrap: break-word;
		}

		.message.user-message .message-bubble {
			background: #2563eb;
			color: #f3f4f6;
		}

		.message.assistant-message .message-bubble {
			background: #374151;
			color: #f3f4f6;
		}

		.message-timestamp {
			font-size: 0.75rem;
			margin-top: 0.25rem;
		}

		.message.user-message .message-timestamp {
			color: #bfdbfe;
			text-align: right;
		}

		.message.assistant-message .message-timestamp {
			color: #9ca3af;
		}

		.message-meta {
			font-size: 0.75rem;
			color: #9ca3af;
			margin-top: 0.5rem;
		}

		.feedback-buttons {
			display: flex;
			gap: 0.5rem;
			margin-top: 0.5rem;
		}

		.feedback-btn {
			background: transparent;
			border: 1px solid #4b5563;
			color: #9ca3af;
			padding: 0.25rem 0.5rem;
			border-radius: 4px;
			cursor: pointer;
			font-size: 0.875rem;
		}

		.feedback-btn:hover {
			border-color: #2563eb;
		}
	</style>
</div>

<script>
	// This component is managed by ChatContainer
</script>

---
export interface Props {
  runId: string | null;
}

const { runId } = Astro.props;

const thumbUpSvg = `<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 10v12"/><path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2h0a3.13 3.13 0 0 1 3 3.88Z"/></svg>`;
const thumbDownSvg = `<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 14V2"/><path d="M9 18.12 10 14H4.17a2 2 0 0 1-1.92-2.56l2.33-8A2 2 0 0 1 6.5 2H20a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-2.76a2 2 0 0 0-1.79 1.11L12 22h0a3.13 3.13 0 0 1-3-3.88Z"/></svg>`;
---

{runId ? (
  <div class="feedback" data-run-id={runId} role="group" aria-label="Feedback">
    <button class="feedback__btn feedback__btn--like" data-type="like" disabled aria-label="Like response" type="button">
      <span class="feedback__icon" set:html={thumbUpSvg} />
      <span class="feedback__label">Like</span>
    </button>
    <button class="feedback__btn feedback__btn--dislike" data-type="dislike" disabled aria-label="Dislike response" type="button">
      <span class="feedback__icon" set:html={thumbDownSvg} />
      <span class="feedback__label">Dislike</span>
    </button>
    <span class="feedback__status" aria-live="polite"></span>
  </div>
) : (
  <div class="feedback feedback--disabled" role="group" aria-label="Feedback unavailable">
    <button class="feedback__btn feedback__btn--like" disabled aria-label="Like response (unavailable)" type="button">
      <span class="feedback__icon" set:html={thumbUpSvg} />
      <span class="feedback__label">Like</span>
    </button>
    <button class="feedback__btn feedback__btn--dislike" disabled aria-label="Dislike response (unavailable)" type="button">
      <span class="feedback__icon" set:html={thumbDownSvg} />
      <span class="feedback__label">Dislike</span>
    </button>
  </div>
)}

<style>
  .feedback {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  .feedback__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-2);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    font-size: 0.875rem;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .feedback__btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .feedback__btn:not(:disabled):hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: var(--color-primary-subtle);
  }

  .feedback__btn:focus-visible {
    outline: 2px solid var(--color-border-focus);
    outline-offset: 2px;
  }

  .feedback__btn--active {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: var(--color-primary-subtle);
  }

  .feedback__icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .feedback__status {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .feedback__status--success {
    color: var(--color-success);
  }

  .feedback__status--error {
    color: var(--color-error);
  }

  .feedback--disabled {
    opacity: 0.5;
  }
</style>

<script>
  import { submitFeedback } from '../utils/api';

  const containers = document.querySelectorAll('.feedback[data-run-id]');

  containers.forEach(container => {
    const el = container as HTMLElement;
    const runId = el.getAttribute('data-run-id');
    const likeBtn = el.querySelector('.feedback__btn--like') as HTMLButtonElement;
    const dislikeBtn = el.querySelector('.feedback__btn--dislike') as HTMLButtonElement;
    const statusEl = el.querySelector('.feedback__status') as HTMLElement;

    if (!runId || !likeBtn || !dislikeBtn || !statusEl) return;

    let activeType: 'like' | 'dislike' | null = null;
    let isSubmitting = false;

    function setStatus(message: string, type: 'success' | 'error' | '') {
      statusEl.textContent = message;
      statusEl.className = `feedback__status${type ? ` feedback__status--${type}` : ''}`;
    }

    function clearStatus() {
      statusEl.textContent = '';
      statusEl.className = 'feedback__status';
    }

    async function handleFeedback(type: 'like' | 'dislike') {
      if (isSubmitting) return;

      isSubmitting = true;
      likeBtn.disabled = true;
      dislikeBtn.disabled = true;
      clearStatus();

      try {
        const result = await submitFeedback(runId, type);

        if (result.status === 'recorded' || result.status === 'accepted') {
          activeType = type;
          clearStatus();

          likeBtn.classList.remove('feedback__btn--active');
          dislikeBtn.classList.remove('feedback__btn--active');

          if (type === 'like') {
            likeBtn.classList.add('feedback__btn--active');
          } else {
            dislikeBtn.classList.add('feedback__btn--active');
          }
        }
      } catch (error) {
        setStatus(
          error instanceof Error ? error.message : 'Failed to save feedback',
          'error'
        );
      } finally {
        isSubmitting = false;
        likeBtn.disabled = false;
        dislikeBtn.disabled = false;
      }
    }

    likeBtn.addEventListener('click', () => handleFeedback('like'));
    dislikeBtn.addEventListener('click', () => handleFeedback('dislike'));
  });
</script>

<div class="feedback">
	<style>
		.feedback {
			display: flex;
			gap: 0.5rem;
			margin-top: 0.5rem;
		}

		.feedback-btn {
			background: transparent;
			border: 1px solid #4b5563;
			color: #9ca3af;
			padding: 0.25rem 0.5rem;
			border-radius: 4px;
			cursor: pointer;
			font-size: 0.875rem;
			transition: all 0.2s;
		}

		.feedback-btn:hover {
			border-color: #10b981;
			color: #10b981;
		}

		.feedback-btn.active {
			background: #10b981;
			border-color: #10b981;
			color: white;
		}

		.feedback-btn.dislike {
			border-color: #ef4444;
			color: #ef4444;
		}

		.feedback-btn.dislike:hover {
			border-color: #ef4444;
			color: #ef4444;
		}

		.feedback-btn.dislike.active {
			background: #ef4444;
			border-color: #ef4444;
			color: white;
		}
	</style>
</div>


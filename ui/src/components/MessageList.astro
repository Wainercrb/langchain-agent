<div class="message-list">
	<style>
		.message-list {
			flex: 1;
			overflow-y: auto;
			padding: 1.5rem;
			display: flex;
			flex-direction: column;
			gap: 1rem;
		}

		.message-list::-webkit-scrollbar {
			width: 8px;
		}

		.message-list::-webkit-scrollbar-track {
			background: #1a1f3a;
		}

		.message-list::-webkit-scrollbar-thumb {
			background: #374151;
			border-radius: 4px;
		}

		.message-list::-webkit-scrollbar-thumb:hover {
			background: #4b5563;
		}

		.message-container {
			display: flex;
			gap: 0.75rem;
			margin-bottom: 0.5rem;
		}

		.message-container.user {
			justify-content: flex-end;
		}

		.message-bubble {
			max-width: 80%;
			padding: 0.75rem 1rem;
			border-radius: 12px;
			word-wrap: break-word;
			line-height: 1.5;
		}

		.message-bubble.user {
			background: #2563eb;
			color: #f3f4f6;
		}

		.message-bubble.assistant {
			background: #374151;
			color: #f3f4f6;
		}

		.message-timestamp {
			font-size: 0.75rem;
			color: #9ca3af;
			margin-top: 0.25rem;
		}

		.message-bubble.user .message-timestamp {
			color: #bfdbfe;
		}

		.message-meta {
			font-size: 0.75rem;
			color: #9ca3af;
			margin-top: 0.5rem;
			display: flex;
			gap: 0.75rem;
			flex-wrap: wrap;
		}

		.feedback-buttons {
			display: flex;
			gap: 0.5rem;
			margin-top: 0.5rem;
		}

		.feedback-btn {
			background: transparent;
			border: 1px solid #4b5563;
			color: #9ca3af;
			padding: 0.25rem 0.5rem;
			border-radius: 4px;
			cursor: pointer;
			font-size: 0.875rem;
			transition: all 0.2s;
		}

		.feedback-btn:hover {
			border-color: #10b981;
			color: #10b981;
		}

		.feedback-btn.liked {
			background: #10b981;
			border-color: #10b981;
			color: white;
		}

		.feedback-btn.disliked {
			background: #ef4444;
			border-color: #ef4444;
			color: white;
		}

		.sources-list {
			margin-top: 0.75rem;
			font-size: 0.85rem;
		}

		.sources-toggle {
			cursor: pointer;
			color: #2563eb;
			text-decoration: underline;
			background: none;
			border: none;
			padding: 0;
			font-size: 0.875rem;
		}

		.sources-content {
			margin-top: 0.5rem;
			padding: 0.5rem;
			background: rgba(55, 65, 81, 0.5);
			border-radius: 4px;
			max-height: 200px;
			overflow-y: auto;
		}

		.source-item {
			padding: 0.25rem 0;
			color: #9ca3af;
		}

		.source-score {
			color: #10b981;
			font-weight: 600;
		}

		@media (max-width: 768px) {
			.message-list {
				padding: 1rem;
			}

			.message-bubble {
				max-width: 90%;
			}

			.message-container {
				gap: 0.5rem;
			}
		}
	</style>
</div>

<script>
	// This component is managed by ChatContainer
	// It provides the structure for messages to be rendered into
</script>

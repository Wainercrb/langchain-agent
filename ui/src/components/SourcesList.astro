	<style>
		.sources-list {
			margin-top: 0.75rem;
			font-size: 0.85rem;
		}

		.sources-toggle {
			cursor: pointer;
			color: #2563eb;
			text-decoration: underline;
			background: none;
			border: none;
			padding: 0;
			font-size: 0.875rem;
		}

		.sources-toggle:hover {
			color: #1d4ed8;
		}

		.sources-content {
			margin-top: 0.5rem;
			padding: 0.5rem;

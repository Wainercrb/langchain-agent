---
// ChatIsland — Client-side interactive chat component
---

<div class="chat-island" role="log" aria-live="polite" aria-label="Chat messages">
  <div class="messages-container" id="messages-container">
    <!-- Empty state -->
    <div class="empty-state" id="empty-state">
      <div class="empty-state__content">
        <p class="empty-state__title">Start a conversation...</p>
        <p class="empty-state__hint">Ask anything about the documents</p>
      </div>
    </div>
  </div>
</div>

<script>
  import { chatWithAgent, checkHealth, submitFeedback, validateSettings } from '../utils/api';
  import type { ChatResponse } from '../utils/api';

  // ============================================
  // Types
  // ============================================

  interface ChatMessage {
    id: string;
    role: 'user' | 'assistant';
    content: string;
    timestamp: Date;
    sources?: Array<{ filename: string; similarity_score: number; content?: string }>;
    executionTime?: number;
    model?: string;
    runId?: string | null;
  }

  interface ChatState {
    messages: ChatMessage[];
    isLoading: boolean;
    settings: { topK: number; temperature: number; includeSources: boolean };
  }

  // ============================================
  // State
  // ============================================

  let state: ChatState = {
    messages: [],
    isLoading: false,
    settings: loadSettings(),
  };

  let healthInterval: number | undefined;
  let resizeTimeout: number | undefined;

  // ============================================
  // Settings
  // ============================================

  function loadSettings() {
    try {
      const raw = {
        topK: localStorage.getItem('topK'),
        temperature: localStorage.getItem('temperature'),
        includeSources: localStorage.getItem('includeSources'),
      };
      return validateSettings({
        topK: raw.topK ? parseInt(raw.topK, 10) : undefined,
        temperature: raw.temperature ? parseFloat(raw.temperature) : undefined,
        includeSources: raw.includeSources ? raw.includeSources === 'true' : undefined,
      });
    } catch {
      return { topK: 5, temperature: 0.7, includeSources: true };
    }
  }

  function saveSettings() {
    localStorage.setItem('topK', String(state.settings.topK));
    localStorage.setItem('temperature', String(state.settings.temperature));
    localStorage.setItem('includeSources', String(state.settings.includeSources));
  }

  // ============================================
  // SVG Icons
  // ============================================

  const icons = {
    bolt: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    copy: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`,
    thumbUp: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 10v12"/><path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2h0a3.13 3.13 0 0 1 3 3.88Z"/></svg>`,
    thumbDown: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 14V2"/><path d="M9 18.12 10 14H4.17a2 2 0 0 1-1.92-2.56l2.33-8A2 2 0 0 1 6.5 2H20a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-2.76a2 2 0 0 0-1.79 1.11L12 22h0a3.13 3.13 0 0 1-3-3.88Z"/></svg>`,
    description: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>`,
  };

  // ============================================
  // Render Message
  // ============================================

  function renderMessage(message: ChatMessage): HTMLElement {
    const wrapper = document.createElement('div');
    wrapper.className = `message message--${message.role}`;

    if (message.role === 'assistant') {
      // AI message: label "FW Agent" with bolt + content bubble
      const label = document.createElement('div');
      label.className = 'message__label';
      label.innerHTML = `<span class="message__label-icon" aria-hidden="true">${icons.bolt}</span><span class="message__label-text">FW Agent</span>`;

      const bubble = document.createElement('div');
      bubble.className = 'message__bubble';

      const content = document.createElement('p');
      content.className = 'message__content';
      content.textContent = message.content;
      bubble.appendChild(content);

      // Attached Files (mockup style)
      if (message.sources && message.sources.length > 0 && state.settings.includeSources) {
        const filesSection = document.createElement('div');
        filesSection.className = 'message__files';

        const filesHeader = document.createElement('div');
        filesHeader.className = 'message__files-header';
        filesHeader.textContent = 'Attached Files';
        filesSection.appendChild(filesHeader);

        message.sources.forEach(src => {
          const fileItem = document.createElement('div');
          fileItem.className = 'message__file';

          const fileIcon = document.createElement('span');
          fileIcon.className = 'message__file-icon';
          fileIcon.innerHTML = icons.description;
          fileItem.appendChild(fileIcon);

          const fileInfo = document.createElement('div');
          fileInfo.className = 'message__file-info';

          const fileName = document.createElement('span');
          fileName.className = 'message__file-name';
          fileName.textContent = src.filename || 'Document';
          fileInfo.appendChild(fileName);

          const fileMeta = document.createElement('span');
          fileMeta.className = 'message__file-meta';
          fileMeta.textContent = 'PDF • 2.4 MB';
          fileInfo.appendChild(fileMeta);

          fileItem.appendChild(fileInfo);
          filesSection.appendChild(fileItem);
        });

        bubble.appendChild(filesSection);
      }

      // Action buttons
      const actions = document.createElement('div');
      actions.className = 'message__actions';

      // Copy
      const copyBtn = document.createElement('button');
      copyBtn.className = 'message__action-btn';
      copyBtn.setAttribute('aria-label', 'Copy message');
      copyBtn.type = 'button';
      copyBtn.innerHTML = icons.copy;
      copyBtn.addEventListener('click', () => {
        navigator.clipboard.writeText(message.content).then(() => {
          copyBtn.setAttribute('data-copied', 'true');
          setTimeout(() => copyBtn.removeAttribute('data-copied'), 2000);
        });
      });
      actions.appendChild(copyBtn);

      if (message.runId) {
        // Thumb up
        const likeBtn = document.createElement('button');
        likeBtn.className = 'message__action-btn';
        likeBtn.setAttribute('aria-label', 'Like response');
        likeBtn.type = 'button';
        likeBtn.innerHTML = icons.thumbUp;
        likeBtn.addEventListener('click', () => handleFeedback(message.runId!, 'like'));
        actions.appendChild(likeBtn);

        // Thumb down
        const dislikeBtn = document.createElement('button');
        dislikeBtn.className = 'message__action-btn';
        dislikeBtn.setAttribute('aria-label', 'Dislike response');
        dislikeBtn.type = 'button';
        dislikeBtn.innerHTML = icons.thumbDown;
        dislikeBtn.addEventListener('click', () => handleFeedback(message.runId!, 'dislike'));
        actions.appendChild(dislikeBtn);
      }

      bubble.appendChild(actions);
      wrapper.appendChild(label);
      wrapper.appendChild(bubble);
    } else {
      // User message: simple bubble
      const bubble = document.createElement('div');
      bubble.className = 'message__bubble message__bubble--user';

      const content = document.createElement('p');
      content.className = 'message__content';
      content.textContent = message.content;
      bubble.appendChild(content);

      wrapper.appendChild(bubble);
    }

    return wrapper;
  }

  function addMessageToDOM(message: ChatMessage) {
    state.messages.push(message);
    const container = document.getElementById('messages-container');
    const emptyState = document.getElementById('empty-state');
    if (emptyState) emptyState.remove();
    if (container) {
      container.appendChild(renderMessage(message));
      container.scrollTop = container.scrollHeight;
    }
  }

  function showLoading(): HTMLElement {
    const wrapper = document.createElement('div');
    wrapper.className = 'message message--assistant';
    wrapper.innerHTML = `
      <div class="message__label">
        <span class="message__label-icon" aria-hidden="true">${icons.bolt}</span>
        <span class="message__label-text">FW Agent</span>
      </div>
      <div class="message__bubble">
        <p class="message__content">Thinking...</p>
      </div>
    `;
    const container = document.getElementById('messages-container');
    if (container) {
      container.appendChild(wrapper);
      container.scrollTop = container.scrollHeight;
    }
    return wrapper;
  }

  function removeLoading(el: HTMLElement) {
    el.remove();
  }

  // ============================================
  // Event Handlers
  // ============================================

  async function handleFeedback(runId: string, type: 'like' | 'dislike') {
    try {
      await submitFeedback(runId, type);
    } catch (error) {
      console.error('Feedback error:', error);
    }
  }

  async function handleSend() {
    const input = document.getElementById('chat-input') as HTMLTextAreaElement;
    const sendBtn = document.getElementById('send-btn') as HTMLButtonElement;
    const query = input.value.trim();

    if (!query || state.isLoading) return;

    state.isLoading = true;
    input.disabled = true;
    sendBtn.disabled = true;

    addMessageToDOM({
      id: crypto.randomUUID(),
      role: 'user',
      content: query,
      timestamp: new Date(),
    });

    input.value = '';
    input.style.height = 'auto';

    const loadingEl = showLoading();

    try {
      const response: ChatResponse = await chatWithAgent(query, state.settings);
      removeLoading(loadingEl);

      addMessageToDOM({
        id: crypto.randomUUID(),
        role: 'assistant',
        content: response.response,
        timestamp: new Date(),
        sources: response.sources?.map(s => ({
          filename: (s.metadata?.filename as string) || 'Document',
          similarity_score: s.similarity_score,
        })),
        executionTime: response.execution_time_ms,
        model: response.model,
        runId: response.run_id,
      });
    } catch (error) {
      removeLoading(loadingEl);
      addMessageToDOM({
        id: crypto.randomUUID(),
        role: 'assistant',
        content: `Error: ${error instanceof Error ? error.message : 'Unknown error'}`,
        timestamp: new Date(),
      });
    } finally {
      state.isLoading = false;
      input.disabled = false;
      sendBtn.disabled = false;
      input.focus();
    }
  }

  async function updateHealth() {
    const isHealthy = await checkHealth();
    const statusDot = document.getElementById('status-dot');
    const statusText = document.getElementById('status-text');
    const sendBtn = document.getElementById('send-btn') as HTMLButtonElement;
    const input = document.getElementById('chat-input') as HTMLTextAreaElement;

    if (statusDot) {
      statusDot.style.background = isHealthy ? 'var(--color-success)' : 'var(--color-error)';
    }
    if (statusText) {
      statusText.textContent = isHealthy ? 'System Online' : 'Offline';
    }
    if (sendBtn) sendBtn.disabled = !isHealthy || state.isLoading;
    if (input) input.disabled = !isHealthy || state.isLoading;
  }

  // ============================================
  // Init
  // ============================================

  function init() {
    document.getElementById('send-btn')?.addEventListener('click', handleSend);

    document.getElementById('chat-input')?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        handleSend();
      }
    });

    // Settings
    document.getElementById('results-toggle')?.addEventListener('change', (e) => {
      state.settings.topK = (e.target as HTMLInputElement).checked ? 10 : 5;
      saveSettings();
    });

    document.getElementById('creativity-toggle')?.addEventListener('change', (e) => {
      state.settings.temperature = (e.target as HTMLInputElement).checked ? 0.9 : 0.7;
      saveSettings();
    });

    document.getElementById('include-sources')?.addEventListener('change', (e) => {
      state.settings.includeSources = (e.target as HTMLInputElement).checked;
      saveSettings();
    });

    // Auto-expand textarea (debounced)
    document.getElementById('chat-input')?.addEventListener('input', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = window.setTimeout(() => {
        const textarea = document.getElementById('chat-input') as HTMLTextAreaElement;
        textarea.style.height = 'auto';
        textarea.style.height = `${Math.min(textarea.scrollHeight, 96)}px`;
      }, 100);
    });

    // Health check
    updateHealth();
    healthInterval = window.setInterval(updateHealth, 5000);
  }

  window.addEventListener('beforeunload', () => {
    if (healthInterval) clearInterval(healthInterval);
    if (resizeTimeout) clearTimeout(resizeTimeout);
  });

  init();
</script>

<style>
  /* ============================================
     Layout
     ============================================ */
  .chat-island {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .messages-container {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-4) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--chat-gap);  /* 1.25rem — Stitch design system */
  }

  /* ============================================
     Empty State
     ============================================ */
  .empty-state {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
  }

  .empty-state__content {
    text-align: center;
    color: var(--color-text-secondary);
  }

  .empty-state__title {
    font-size: 1rem;
    margin: 0 0 var(--space-1);
  }

  .empty-state__hint {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ============================================
     Message
     ============================================ */
  .message {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .message--user {
    align-items: flex-end;
  }

  .message--assistant {
    align-items: flex-start;
  }

  .message__label {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: 0 var(--space-2);
  }

  .message__label-icon {
    display: flex;
    align-items: center;
    color: var(--color-primary);
  }

  .message__label-text {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .message__bubble {
    max-width: 80%;
    padding: var(--space-3) var(--space-4);
    word-break: break-word;
  }

  .message__bubble--user {
    background: var(--color-primary);
    color: white;
    border-radius: var(--radius-lg) var(--radius-lg) var(--radius-sm) var(--radius-lg);
  }

  .message__bubble:not(.message__bubble--user) {
    background: var(--color-ai-bubble);  /* #f8fafc — Stitch secondary */
    border-radius: var(--radius-lg) var(--radius-lg) var(--radius-lg) var(--radius-sm);
  }

  .message__content {
    margin: 0;
    font-size: 1rem;  /* Stitch body-lg: 16px */
    line-height: 1.625;  /* 26px line-height */
  }

  .message__bubble--user .message__content {
    color: white;
  }

  /* ============================================
     Attached Files (Mockup style)
     ============================================ */
  .message__files {
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
  }

  .message__files-header {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2);
  }

  .message__file {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-1);
  }

  .message__file-icon {
    display: flex;
    align-items: center;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .message__file-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .message__file-name {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .message__file-meta {
    font-size: 0.625rem;
    color: var(--color-text-muted);
  }

  /* ============================================
     Action Buttons
     ============================================ */
  .message__actions {
    display: flex;
    gap: var(--space-1);
    margin-top: var(--space-2);
  }

  .message__action-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    padding: 0;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .message__action-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: var(--color-primary-subtle);
  }

  .message__action-btn[data-copied="true"] {
    border-color: var(--color-success);
    color: var(--color-success);
  }

  .message__action-btn:focus-visible {
    outline: 2px solid var(--color-border-focus);
    outline-offset: 2px;
  }
</style>

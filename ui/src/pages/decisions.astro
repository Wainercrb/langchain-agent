---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Audit Trail">
  <header class="mb-6 flex items-baseline justify-between">
    <h1 class="text-2xl font-bold text-[var(--color-text)]">Decision Audit Trail</h1>
    <time id="last-updated" class="text-xs text-[var(--color-text-muted)]">--</time>
  </header>

  <!-- Loading state -->
  <div id="loading-state" class="flex items-center justify-center rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-12">
    <p class="text-sm text-[var(--color-text-muted)]">Loading decisions...</p>
  </div>

  <!-- Error state -->
  <div id="error-state" class="hidden rounded-lg border border-[var(--color-error)]/30 bg-[var(--color-error)]/5 p-8 text-center">
    <p class="text-sm font-medium text-[var(--color-error)]">Unable to load decisions</p>
    <p id="error-message" class="mt-1 text-xs text-[var(--color-text-muted)]"></p>
    <button id="retry-btn" type="button" class="mt-4 rounded-md bg-[var(--color-error)] px-5 py-2 text-sm font-medium text-white transition-colors hover:bg-[var(--color-error)]/90">Retry</button>
  </div>

  <!-- Empty state -->
  <div id="empty-state" class="hidden rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-12 text-center">
    <p class="text-sm text-[var(--color-text-muted)]">No decisions recorded</p>
  </div>

  <!-- Table -->
  <div id="table-wrapper" class="hidden overflow-x-auto rounded-lg border border-[var(--color-border)]">
    <table class="w-full border-collapse text-left text-sm">
      <thead>
        <tr class="border-b border-[var(--color-border)] bg-[var(--color-surface-elevated)]">
          <th class="px-4 py-3 font-semibold text-[var(--color-text)]">Time</th>
          <th class="px-4 py-3 font-semibold text-[var(--color-text)]">Query</th>
          <th class="px-4 py-3 font-semibold text-[var(--color-text)]">Quality</th>
          <th class="px-4 py-3 font-semibold text-[var(--color-text)]">Model</th>
          <th class="px-4 py-3 font-semibold text-[var(--color-text)]">Tools</th>
        </tr>
      </thead>
      <tbody id="decisions-tbody"></tbody>
    </table>
  </div>
</Layout>

<script>
  import { fetchDecisions } from '../utils/api';
  import type { DecisionRecord } from '../utils/api';

  async function loadDecisions() {
    const loadingEl = document.getElementById('loading-state');
    const errorEl = document.getElementById('error-state');
    const emptyEl = document.getElementById('empty-state');
    const tableWrapper = document.getElementById('table-wrapper');
    const tbody = document.getElementById('decisions-tbody');
    const errorMsg = document.getElementById('error-message');
    const timeEl = document.getElementById('last-updated');

    loadingEl?.classList.remove('hidden');
    errorEl?.classList.add('hidden');
    emptyEl?.classList.add('hidden');
    tableWrapper?.classList.add('hidden');

    try {
      const res = await fetchDecisions();

      loadingEl?.classList.add('hidden');

      if (!res.decisions || res.decisions.length === 0) {
        emptyEl?.classList.remove('hidden');
        if (timeEl) timeEl.textContent = new Date().toLocaleString();
        return;
      }

      if (tbody) {
        tbody.innerHTML = res.decisions.map((row: DecisionRecord, i: number) => `
          <tr class="${i % 2 === 0 ? 'bg-[var(--color-surface)]' : 'bg-[var(--color-bg)]'} border-b border-[var(--color-border)] last:border-b-0 transition-colors hover:bg-[var(--color-surface-elevated)] cursor-pointer" onclick="window.location='/decisions/detail?run_id=${encodeURIComponent(row.run_id)}'">
            <td class="px-4 py-3 text-xs text-[var(--color-text-muted)] whitespace-nowrap">${escapeHtml(formatTime(row.timestamp))}</td>
            <td class="px-4 py-3 text-[var(--color-text)] max-w-xs truncate" title="${escapeHtml(row.query_preview)}">${escapeHtml(row.query_preview)}</td>
            <td class="px-4 py-3">
              <span class="inline-block rounded-full px-2.5 py-0.5 text-xs font-medium ${qualityClass(row.decision_quality)}">${escapeHtml(row.decision_quality)}</span>
            </td>
            <td class="px-4 py-3 text-xs text-[var(--color-text-secondary)]">${escapeHtml(shortModel(row.model_used))}</td>
            <td class="px-4 py-3 text-xs text-[var(--color-text-secondary)]">${row.chain_length > 0 ? `${row.chain_length} tool${row.chain_length > 1 ? 's' : ''}` : '—'}</td>
          </tr>
        `).join('');
      }

      tableWrapper?.classList.remove('hidden');
      if (timeEl) timeEl.textContent = new Date().toLocaleString();
    } catch (err) {
      loadingEl?.classList.add('hidden');
      errorEl?.classList.remove('hidden');
      if (errorMsg) {
        errorMsg.textContent = err instanceof Error ? err.message : 'An unexpected error occurred';
      }
    }
  }

  function qualityClass(quality: string): string {
    const q = quality.toLowerCase();
    if (q === 'optimal') return 'bg-green-100 text-green-800';
    if (q === 'suboptimal') return 'bg-yellow-100 text-yellow-800';
    if (q === 'poor') return 'bg-red-100 text-red-800';
    return 'bg-gray-100 text-gray-700';
  }

  function shortModel(model: string): string {
    return model.length > 30 ? model.slice(0, 28) + '…' : model;
  }

  function formatTime(ts: string): string {
    try {
      const d = new Date(ts);
      const now = new Date();
      const isToday = d.toDateString() === now.toDateString();
      const time = d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      if (isToday) return `Today, ${time}`;
      const yesterday = new Date(now);
      yesterday.setDate(yesterday.getDate() - 1);
      if (d.toDateString() === yesterday.toDateString()) return `Yesterday, ${time}`;
      return `${d.toLocaleDateString([], { month: 'short', day: 'numeric' })}, ${time}`;
    } catch {
      return ts;
    }
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  document.getElementById('retry-btn')?.addEventListener('click', loadDecisions);

  loadDecisions();
</script>

---
import ChatContainer from '../components/ChatContainer.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Chat with RAG">
	<style define:vars={{ bgColor: '#0a0e27' }}>
		:global(html, body) {
			background-color: var(--bgColor);
		}

		.chat-page {
			width: 100%;
			height: 100vh;
			display: flex;
			flex-direction: column;
			color: #f3f4f6;
		}
	</style>

	<div class="chat-page">
		<ChatContainer client:load />
	</div>
</Layout>

---
import ChatContainer from '../components/ChatContainer.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Chat with RAG">
	<ChatContainer />

	<script>
		import { chatWithAgent, checkHealth, submitFeedback } from '../utils/api';

		// Initialize chat functionality
		async function initializeChat() {
			// Get elements
			const inputField = document.querySelector('textarea') as HTMLTextAreaElement;
			const sendBtn = document.querySelector('button[aria-label="Send message"]');
			const messagesArea = document.querySelector('div.overflow-y-auto');
			
			// Find status badge using data attribute
			const statusBadge = document.querySelector('[data-status-badge="true"]') as HTMLElement;
			const statusDot = statusBadge?.children[0] as HTMLElement;
			const statusText = statusBadge?.children[1] as HTMLElement;

			if (!inputField || !sendBtn || !messagesArea) {
				console.error('Chat elements not found');
				return;
			}

			// Health check function
			async function updateHealthStatus() {
				try {
					const isHealthy = await checkHealth();
					if (statusDot && statusText) {
						if (isHealthy) {
							statusDot.className = 'w-2 h-2 bg-green-500 rounded-full animate-pulse';
							statusText.textContent = 'Online';
							statusText.className = 'text-xs font-medium text-green-700';
							sendBtn.disabled = false;
							inputField.disabled = false;
						} else {
							statusDot.className = 'w-2 h-2 bg-red-500 rounded-full';
							statusText.textContent = 'Offline';
							statusText.className = 'text-xs font-medium text-red-700';
							sendBtn.disabled = true;
							inputField.disabled = true;
						}
					}
				} catch (error) {
					console.error('Health check error:', error);
					if (statusDot && statusText) {
						statusDot.className = 'w-2 h-2 bg-red-500 rounded-full';
						statusText.textContent = 'Offline';
						statusText.className = 'text-xs font-medium text-red-700';
						sendBtn.disabled = true;
						inputField.disabled = true;
					}
				}
			}

			// Set status to Loading
			function setStatusLoading() {
				if (statusDot && statusText) {
					statusDot.className = 'w-2 h-2 bg-yellow-500 rounded-full animate-pulse';
					statusText.textContent = 'Loading';
					statusText.className = 'text-xs font-medium text-yellow-700';
					sendBtn.disabled = true;
					inputField.disabled = true;
				}
			}

			// Check health on page load
			await updateHealthStatus();

			// Check health every 5 seconds
			setInterval(updateHealthStatus, 5000);

			// Get settings elements
			const topKInput = document.querySelector('input[name="topK"]') as HTMLInputElement;
			const tempInput = document.querySelector('input[name="temperature"]') as HTMLInputElement;
			const sourceToggle = document.querySelector('input[name="includeSources"]') as HTMLInputElement;

			// Load saved settings from localStorage
			if (topKInput) topKInput.value = localStorage.getItem('topK') || '5';
			if (tempInput) tempInput.value = localStorage.getItem('temperature') || '0.7';
			if (sourceToggle) sourceToggle.checked = localStorage.getItem('includeSources') !== 'false';

			// Save settings on change
			[topKInput, tempInput, sourceToggle].forEach(el => {
				if (el) {
					el.addEventListener('change', () => {
						if (topKInput) localStorage.setItem('topK', topKInput.value);
						if (tempInput) localStorage.setItem('temperature', tempInput.value);
						if (sourceToggle) localStorage.setItem('includeSources', sourceToggle.checked.toString());
					});
				}
			});

			// Clear empty state
			const clearEmptyState = () => {
				const emptyState = messagesArea.querySelector('[class*="items-center"]');
				if (emptyState) emptyState.remove();
			};

			// Handle send button click
			async function handleSendMessage() {
				const query = inputField.value.trim();
				if (!query) return;

				clearEmptyState();

				// Add user message
				addUserMessage(query);
				inputField.value = '';
				inputField.style.height = 'auto';
				
				// Set status to Loading while making request
				setStatusLoading();

				// Show loading state
				const loadingEl = addAssistantMessage('⏳ Thinking...');

				try {
					const settings = {
						topK: parseInt(topKInput?.value || '5'),
						temperature: parseFloat(tempInput?.value || '0.7'),
						includeSources: sourceToggle?.checked ?? true,
					};

					const response = await chatWithAgent(query, settings);

					// Remove loading message
					loadingEl.remove();

					// Add assistant message
					addAssistantMessage(
						response.response,
						response.sources,
						response.execution_time_ms,
						response.model,
						response.run_id ?? null
					);
					
					// Update status back to Online after successful response
					await updateHealthStatus();
				} catch (error) {
					loadingEl.remove();
					let errorMsg = 'Unknown error';
					if (error instanceof Error) {
						errorMsg = error.message;
					} else if (typeof error === 'string') {
						errorMsg = error;
					} else if (error && typeof error === 'object') {
						errorMsg = (error as any).detail || JSON.stringify(error);
					}
					addAssistantMessage(`❌ Error: ${errorMsg}`);
					
					// Update status back to Online/Offline after error
					await updateHealthStatus();
				} finally {
					inputField.focus();
				}
			}

			function addUserMessage(content: string) {
				const msg = document.createElement('div');
				msg.className = 'flex justify-end';
				msg.innerHTML = `
					<div class="max-w-xs lg:max-w-md xl:max-w-lg px-4 py-3 bg-blue-600 text-white rounded-2xl rounded-tr-sm break-words">
						<p class="m-0 text-sm">${escapeHtml(content)}</p>
					</div>
				`;
				messagesArea.appendChild(msg);
				messagesArea.scrollTop = messagesArea.scrollHeight;
				return msg;
			}

			function addAssistantMessage(
				content: string,
				sources?: any[],
				executionTime?: number,
				model?: string,
				runId?: string | null
			): HTMLElement {
				const msg = document.createElement('div');
				msg.className = 'flex justify-start';

				let sourcesHtml = '';
				if (sources && sources.length > 0) {
					sourcesHtml = `
						<details class="mt-2 w-full">
							<summary class="cursor-pointer text-xs font-semibold text-blue-600 hover:text-blue-700">📄 Sources (${sources.length})</summary>
							<div class="mt-2 space-y-1 pl-2 border-l border-blue-300">
								${sources
									.map(
										(src) => `
									<div class="text-xs text-gray-600">
										<div class="font-medium">${escapeHtml(src.filename || 'Document')}</div>
										<div class="text-gray-500">Match: ${(src.similarity_score * 100).toFixed(0)}%</div>
									</div>
								`
									)
									.join('')}
							</div>
						</details>
					`;
				}

				let metricsHtml = '';
				if (executionTime || model) {
					metricsHtml = `
						<div class="mt-2 flex gap-3 flex-wrap text-xs text-gray-500">
							${executionTime ? `<span>⏱️ ${executionTime.toFixed(0)}ms</span>` : ''}
							${model ? `<span>🤖 ${escapeHtml(model)}</span>` : ''}
						</div>
					`;
				}

				let feedbackHtml = '';
				if (runId) {
					feedbackHtml = `
						<div class="mt-3 flex gap-2 items-center" data-msg-run-id="${runId}">
							<button class="feedback-like px-2 py-1 text-sm border border-green-300 text-green-600 rounded hover:bg-green-50 transition disabled:opacity-40 disabled:cursor-not-allowed" data-feedback="like">👍 Like</button>
							<button class="feedback-dislike px-2 py-1 text-sm border border-red-300 text-red-600 rounded hover:bg-red-50 transition disabled:opacity-40 disabled:cursor-not-allowed" data-feedback="dislike">👎 Dislike</button>
							<span class="feedback-msg text-xs text-gray-500"></span>
						</div>
					`;
				} else {
					feedbackHtml = `
						<div class="mt-3 flex gap-2 items-center">
							<button class="feedback-like px-2 py-1 text-sm border border-gray-300 text-gray-400 rounded cursor-not-allowed opacity-40" disabled>👍 Like</button>
							<button class="feedback-dislike px-2 py-1 text-sm border border-gray-300 text-gray-400 rounded cursor-not-allowed opacity-40" disabled>👎 Dislike</button>
						</div>
					`;
				}

				msg.innerHTML = `
					<div class="max-w-xs lg:max-w-md xl:max-w-lg px-4 py-3 bg-gray-200 text-gray-900 rounded-2xl rounded-tl-sm break-words">
						<p class="m-0 text-sm leading-relaxed">${escapeHtml(content)}</p>
						${metricsHtml}
						${feedbackHtml}
						${sourcesHtml}
					</div>
				`;

				messagesArea.appendChild(msg);
				messagesArea.scrollTop = messagesArea.scrollHeight;

				// Add feedback listeners
				const feedbackContainer = msg.querySelector('[data-msg-run-id]');
				const msgRunId = feedbackContainer?.getAttribute('data-msg-run-id');
				if (feedbackContainer && msgRunId) {
					const likeBtn = feedbackContainer.querySelector('[data-feedback="like"]') as HTMLButtonElement;
					const dislikeBtn = feedbackContainer.querySelector('[data-feedback="dislike"]') as HTMLButtonElement;
					const feedbackStatus = feedbackContainer.querySelector('.feedback-msg') as HTMLElement;

					let isSubmitting = false;
					let activeType: string | null = null;

					function setFeedbackStatus(text: string, type?: 'success' | 'error') {
						if (!feedbackStatus) return;
						feedbackStatus.textContent = text;
						feedbackStatus.className = 'feedback-msg text-xs' + (type === 'error' ? ' text-red-500' : type === 'success' ? ' text-green-500' : ' text-gray-500');
					}

					async function handleFeedback(type: 'like' | 'dislike') {
						if (isSubmitting) return;

						isSubmitting = true;
						likeBtn.disabled = true;
						dislikeBtn.disabled = true;
						setFeedbackStatus('Saving...');

						try {
							const result = await submitFeedback(msgRunId, type);

							if (result.status === 'recorded' || result.status === 'accepted') {
								activeType = type;
								setFeedbackStatus('');

								// Highlight selected button
								likeBtn.classList.remove('bg-green-500/20', 'border-green-500/60');
								dislikeBtn.classList.remove('bg-red-500/20', 'border-red-500/60');
								if (type === 'like') {
									likeBtn.classList.add('bg-green-500/20', 'border-green-500/60');
								} else {
									dislikeBtn.classList.add('bg-red-500/20', 'border-red-500/60');
								}
							}
						} catch (error) {
							setFeedbackStatus(
								error instanceof Error ? error.message : 'Failed to save',
								'error'
							);
						} finally {
							isSubmitting = false;
							likeBtn.disabled = false;
							dislikeBtn.disabled = false;
						}
					}

					likeBtn.addEventListener('click', () => handleFeedback('like'));
					dislikeBtn.addEventListener('click', () => handleFeedback('dislike'));
				}

				return msg;
			}

			function escapeHtml(text: string): string {
				const div = document.createElement('div');
				div.textContent = text;
				return div.innerHTML;
			}

			// Send on button click
			sendBtn.addEventListener('click', handleSendMessage);

			// Send on Enter (but not Shift+Enter)
			inputField.addEventListener('keydown', (e: KeyboardEvent) => {
				if (e.key === 'Enter' && !e.shiftKey) {
					e.preventDefault();
					handleSendMessage();
				}
			});
		}

		// Initialize when DOM is ready
		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', initializeChat);
		} else {
			initializeChat();
		}
	</script>
</Layout>

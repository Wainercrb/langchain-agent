---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Decision Detail">
  <header class="mb-6 flex items-baseline justify-between">
    <h1 class="text-2xl font-bold text-[var(--color-text)]">Decision Detail</h1>
    <a href="/decisions" class="text-xs text-[var(--color-primary)] hover:underline">&larr; Back to list</a>
  </header>

  <!-- Loading state -->
  <div id="loading-state" class="flex items-center justify-center rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-12">
    <p class="text-sm text-[var(--color-text-muted)]">Loading decision...</p>
  </div>

  <!-- Error state -->
  <div id="error-state" class="hidden rounded-lg border border-[var(--color-error)]/30 bg-[var(--color-error)]/5 p-8 text-center">
    <p class="text-sm font-medium text-[var(--color-error)]">Unable to load decision</p>
    <p id="error-message" class="mt-1 text-xs text-[var(--color-text-muted)]"></p>
    <a href="/decisions" class="mt-4 inline-block rounded-md bg-[var(--color-primary)] px-5 py-2 text-sm font-medium text-white transition-colors hover:bg-[var(--color-primary-hover)]">&larr; Back to list</a>
  </div>

  <!-- Content -->
  <div id="content" class="hidden space-y-6"></div>
</Layout>

<script>
  const API_BASE = import.meta.env.PUBLIC_API_URL || '';

  const params = new URLSearchParams(window.location.search);
  const runId = params.get('run_id');

  if (!runId) {
    document.getElementById('loading-state')?.classList.add('hidden');
    const err = document.getElementById('error-state');
    err?.classList.remove('hidden');
    document.getElementById('error-message')!.textContent = 'Missing run_id parameter';
  } else {
    loadDecision(runId);
  }

  async function loadDecision(id: string) {
    try {
      const res = await fetch(`${API_BASE}/v1/decisions/${encodeURIComponent(id)}`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();

      document.getElementById('loading-state')?.classList.add('hidden');
      renderDecision(data);
    } catch (err) {
      document.getElementById('loading-state')?.classList.add('hidden');
      const errEl = document.getElementById('error-state');
      errEl?.classList.remove('hidden');
      document.getElementById('error-message')!.textContent = err instanceof Error ? err.message : 'Failed to load';
    }
  }

  function qualityBadge(quality: string): string {
    const q = quality.toLowerCase();
    if (q === 'optimal') return 'bg-green-100 text-green-800';
    if (q === 'suboptimal') return 'bg-yellow-100 text-yellow-800';
    if (q === 'poor') return 'bg-red-100 text-red-800';
    return 'bg-gray-100 text-gray-700';
  }

  function feedbackBadge(feedback: Record<string, unknown> | null): string {
    if (!feedback) return '<span class="text-[var(--color-text-muted)]">No feedback</span>';
    const type = (feedback as any).feedback_type || 'unknown';
    const cls = type === 'like' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800';
    return `<span class="inline-block rounded-full px-2.5 py-0.5 text-xs font-medium ${cls}">${type}</span>`;
  }

  function renderDecision(d: any) {
    const content = document.getElementById('content')!;
    content.classList.remove('hidden');

    const sections: string[] = [];

    // ── Query ──────────────────────────────────────────────
    sections.push(`
      <section class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-sm">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Query</h3>
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-base font-medium text-[var(--color-text)]">${escapeHtml(d.query_preview || '')}</p>
            <p class="mt-1 text-xs text-[var(--color-text-muted)]">${escapeHtml(formatTime(d.timestamp))}</p>
          </div>
          <span class="shrink-0 inline-block rounded-full px-3 py-1 text-xs font-medium ${qualityBadge(d.decision_quality)}">${escapeHtml(d.decision_quality)}</span>
        </div>
      </section>
    `);

    // ── Execution ───────────────────────────────────────────
    sections.push(`
      <section class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-sm">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Execution</h3>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-sm">
          <div>
            <span class="block text-xs text-[var(--color-text-muted)]">Agent</span>
            <span class="font-medium text-[var(--color-text)]">${escapeHtml(d.agent_type || '—')}</span>
          </div>
          <div>
            <span class="block text-xs text-[var(--color-text-muted)]">Model</span>
            <span class="font-medium text-[var(--color-text)]">${escapeHtml(d.model_used || '—')}</span>
          </div>
          <div>
            <span class="block text-xs text-[var(--color-text-muted)]">Latency</span>
            <span class="font-medium text-[var(--color-text)]">${d.latency_ms != null ? `${Math.round(d.latency_ms)}ms` : '—'}</span>
          </div>
          <div>
            <span class="block text-xs text-[var(--color-text-muted)]">Chain Length</span>
            <span class="font-medium text-[var(--color-text)]">${d.chain_length != null ? d.chain_length : '—'}</span>
          </div>
        </div>
      </section>
    `);

    // ── Configuration ───────────────────────────────────────
    sections.push(`
      <section class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-sm">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Configuration</h3>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-sm">
          <div>
            <span class="block text-xs text-[var(--color-text-muted)]">Top K</span>
            <span class="font-medium text-[var(--color-text)]">${d.top_k != null ? d.top_k : '—'}</span>
          </div>
          <div>
            <span class="block text-xs text-[var(--color-text-muted)]">Temperature</span>
            <span class="font-medium text-[var(--color-text)]">${d.temperature != null ? d.temperature : '—'}</span>
          </div>
        </div>
      </section>
    `);

    // ── Tools / Tool Chain ──────────────────────────────────
    if (d.chain_tools && d.chain_tools.length > 0) {
      sections.push(`
        <section class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-sm">
          <h3 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Tool Chain (${d.chain_tools.length})</h3>
          <div class="space-y-3">
            ${d.chain_tools.map((t: any, i: number) => `
              <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] p-4">
                <div class="flex items-center gap-2 mb-2">
                  <span class="flex items-center justify-center w-5 h-5 rounded-full bg-[var(--color-primary-subtle)] text-[var(--color-primary)] text-[10px] font-bold">${i + 1}</span>
                  <span class="text-sm font-semibold text-[var(--color-text)]">${escapeHtml(t.tool_name || 'unknown')}</span>
                </div>
                ${t.tool_input && Object.keys(t.tool_input).length > 0 ? `
                <div class="mb-2">
                  <span class="text-xs text-[var(--color-text-muted)]">Input:</span>
                  <pre class="mt-1 text-xs text-[var(--color-text-secondary)] bg-[var(--color-surface-elevated)] rounded p-2 overflow-x-auto">${escapeHtml(JSON.stringify(t.tool_input, null, 2))}</pre>
                </div>` : ''}
                ${t.output_summary ? `
                <div>
                  <span class="text-xs text-[var(--color-text-muted)]">Output:</span>
                  <p class="mt-1 text-xs text-[var(--color-text-secondary)]">${escapeHtml(t.output_summary)}</p>
                </div>` : ''}
              </div>
            `).join('')}
          </div>
        </section>
      `);
    } else if (d.tools_used && d.tools_used.length > 0) {
      sections.push(`
        <section class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-sm">
          <h3 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Tools Used</h3>
          <div class="flex flex-wrap gap-2">
            ${d.tools_used.map((t: string) => `
              <span class="inline-block rounded-full px-3 py-1 text-xs font-medium bg-[var(--color-primary-subtle)] text-[var(--color-primary)]">${escapeHtml(t)}</span>
            `).join('')}
          </div>
        </section>
      `);
    }

    // ── Reasoning ───────────────────────────────────────────
    if (d.reasoning_summary) {
      sections.push(`
        <section class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-sm">
          <h3 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Reasoning</h3>
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed whitespace-pre-wrap">${escapeHtml(d.reasoning_summary)}</p>
          ${d.tool_selection_rationale ? `
          <div class="mt-4 pt-4 border-t border-[var(--color-border)]">
            <h4 class="text-xs font-semibold text-[var(--color-text-muted)] mb-2">Tool Selection Rationale</h4>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed whitespace-pre-wrap">${escapeHtml(d.tool_selection_rationale)}</p>
          </div>` : ''}
        </section>
      `);
    } else if (d.tool_selection_rationale) {
      sections.push(`
        <section class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-sm">
          <h3 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Tool Selection Rationale</h3>
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed whitespace-pre-wrap">${escapeHtml(d.tool_selection_rationale)}</p>
        </section>
      `);
    }

    // ── Metadata ────────────────────────────────────────────
    sections.push(`
      <section class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-sm">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Metadata</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
          <div>
            <span class="block text-xs text-[var(--color-text-muted)]">Run ID</span>
            <span class="font-mono text-xs text-[var(--color-text-secondary)] break-all">${escapeHtml(d.run_id)}</span>
          </div>
          <div>
            <span class="block text-xs text-[var(--color-text-muted)]">Query Hash</span>
            <span class="font-mono text-xs text-[var(--color-text-secondary)] break-all">${escapeHtml(d.query_hash || '—')}</span>
          </div>
          <div>
            <span class="block text-xs text-[var(--color-text-muted)]">Feedback</span>
            ${feedbackBadge(d.user_feedback)}
          </div>
        </div>
      </section>
    `);

    content.innerHTML = sections.join('');
  }

  function formatTime(ts: string): string {
    try {
      const d = new Date(ts);
      const now = new Date();
      const isToday = d.toDateString() === now.toDateString();
      const time = d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      if (isToday) return `Today, ${time}`;
      const yesterday = new Date(now);
      yesterday.setDate(yesterday.getDate() - 1);
      if (d.toDateString() === yesterday.toDateString()) return `Yesterday, ${time}`;
      return `${d.toLocaleDateString([], { month: 'short', day: 'numeric' })}, ${time}`;
    } catch {
      return ts;
    }
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }
</script>

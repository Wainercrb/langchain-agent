---
import '../styles/globals.css';
import Sidebar from '../components/Sidebar.astro';
import HamburgerToggle from '../components/HamburgerToggle.astro';

interface Props {
	title?: string;
}

const { title = "Chat with RAG" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="Chat with FW Agent - AI-powered document assistant" />
		<meta name="theme-color" content="#4648d4" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content="AI-powered document assistant" />
		<meta property="og:type" content="website" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="m-0 flex h-screen w-full">
		<!-- Mobile backdrop overlay -->
		<div
			id="sidebar-backdrop"
			class="fixed inset-0 z-30 bg-black/50 hidden max-md:[html.sidebar-open_&]:block md:hidden"
			aria-hidden="true"
		></div>

		<!-- Sidebar navigation -->
		<Sidebar currentPath={currentPath} />

		<!-- Main content area -->
		<div class="flex flex-1 flex-col md:ml-60">
			<!-- Mobile hamburger (hidden on desktop) -->
			<div class="flex items-center px-4 py-3 md:hidden">
				<HamburgerToggle />
			</div>

			<slot />
		</div>
	</body>
</html>

---
import '../styles/globals.css';

interface Props {
	title?: string;
}

const { title = "Chat with RAG" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="Chat with FW Agent - AI-powered document assistant" />
		<meta name="theme-color" content="#6366f1" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content="AI-powered document assistant" />
		<meta property="og:type" content="website" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="m-0 w-full h-screen">
		<slot />
	</body>
</html>

# =============================================================================
# LangChain Agent RAG System — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED]
# Optional variables have default values in config/settings.py
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Google / Gemini (Embeddings)
# ─────────────────────────────────────────────────────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikeys

GOOGLE_API_KEY=your_google_api_key_here  # [REQUIRED]

# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_TEMPERATURE=0.7

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI (LLM Provider — Alternative)
# ─────────────────────────────────────────────────────────────────────────────
# Get your API key from: https://platform.openai.com/api-keys

# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TEMPERATURE=0.7

# ─────────────────────────────────────────────────────────────────────────────
# OpenRouter (LLM Provider — Default)
# ─────────────────────────────────────────────────────────────────────────────
# Get your API key from: https://openrouter.ai/keys
# OpenRouter provides access to multiple LLM providers through a unified API

OPENROUTER_API_KEY=your_openrouter_api_key_here  # [REQUIRED]

# OPENROUTER_MODEL=openai/gpt-4o
# OPENROUTER_TEMPERATURE=0.7
# OPENROUTER_MAX_TOKENS=2000

# ─────────────────────────────────────────────────────────────────────────────
# Supabase / pgvector (Vector Database)
# ─────────────────────────────────────────────────────────────────────────────
# Create a project at: https://supabase.com
# Find these values in: Project Settings → API

SUPABASE_URL=https://your-project.supabase.co  # [REQUIRED]
SUPABASE_KEY=your_supabase_service_role_key_here  # [REQUIRED]
SUPABASE_DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres  # [REQUIRED]

# ─────────────────────────────────────────────────────────────────────────────
# Document Ingestion
# ─────────────────────────────────────────────────────────────────────────────
# Cronjob polls knowledge/raw_docs/ and processes new files

# CRON_INTERVAL_MINUTES=5

# Directory paths (relative to project root)
# KNOWLEDGE_DIR=./knowledge/raw_docs
# PROCESSED_DIR=./knowledge/processed
# FAILED_DIR=./knowledge/failed

# Text splitting configuration
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# EMBEDDING_RETRIES=3

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────
# Structured JSON logging to console (local dev) or AWS CloudWatch (prod)

# LOG_LEVEL=INFO
# LOGGER_BACKEND=console  # Options: console, cloudwatch

# ─────────────────────────────────────────────────────────────────────────────
# AWS CloudWatch Logs (when LOGGER_BACKEND=cloudwatch)
# ─────────────────────────────────────────────────────────────────────────────
# Credentials: explicit keys, IAM role, or environment variables
# If running on EC2/ECS/Lambda with an IAM role, keys are not needed.

# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# CLOUDWATCH_LOG_GROUP=langchain-agent
# CLOUDWATCH_STREAM_NAME=default

# ─────────────────────────────────────────────────────────────────────────────
# CORS (Cross-Origin Resource Sharing)
# ─────────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API

# CORS_ORIGINS=http://localhost:4321,http://localhost:3000,http://127.0.0.1:4321,http://127.0.0.1:3000

# ─────────────────────────────────────────────────────────────────────────────
# Alerts (Discord & Slack Webhooks)
# ─────────────────────────────────────────────────────────────────────────────
# Create a webhook in Discord: Server Settings → Integrations → Webhooks
# Create a webhook in Slack: Apps → Incoming Webhooks

# DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/...
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# ALERT_RATE_LIMIT_PER_MINUTE=5

# ─────────────────────────────────────────────────────────────────────────────
# Active Monitoring (Production Checklists)
# ─────────────────────────────────────────────────────────────────────────────
# Turns on the background MonitoringScheduler that runs automated health
# checks (db, langsmith, embeddings, tracing_completeness, memory usage,
# log rotation, decision drift) on a fixed interval and dispatches
# Discord/Slack alerts when any check fails.
# WITHOUT THIS, the runbooks in docs/runbooks/ are the only monitoring.

# MONITORING_ENABLED=true
# MONITORING_INTERVAL_SECONDS=300
# MONITORING_MEMORY_THRESHOLD_MB=512
# MONITORING_LOG_MAX_AGE_HOURS=24
# MONITORING_TRACING_WINDOW_SECONDS=300

# ─────────────────────────────────────────────────────────────────────────────
# Maintenance Schedule (Automated Runbook Items)
# ─────────────────────────────────────────────────────────────────────────────
# These 2 items from docs/runbooks/weekly-maintenance.md are now scheduled
# by agent/cronjob.py alongside the ingestion cycle. Set to "false" to
# keep the item as a manual runbook task only.
# Log rotation is managed by CloudWatch retention policies.
#   - weekly_backup        (Sundays 02:00)  — runs scripts/backup.py
#   - weekly_vacuum_analyze (Sundays 04:00) — runs psql on Supabase

# MAINTENANCE_BACKUP_ENABLED=true
# MAINTENANCE_VACUUM_ENABLED=true
# MAINTENANCE_BACKUP_RETENTION=7

# ─────────────────────────────────────────────────────────────────────────────
# Traffic Shedding
# ─────────────────────────────────────────────────────────────────────────────
# When MONITORING_ENABLED=true and overall_status="error", the
# TrafficSheddingMiddleware returns 503 with Retry-After to protect
# the system from cascading failures.

# TRAFFIC_SHEDDING_ENABLED=false
# TRAFFIC_SHEDDING_RETRY_AFTER=60

# ─────────────────────────────────────────────────────────────────────────────
# LLM Resilience
# ─────────────────────────────────────────────────────────────────────────────
# Timeout and retry configuration for LLM API calls

# LLM_TIMEOUT_SECONDS=60
# LLM_MAX_RETRIES=3

# ─────────────────────────────────────────────────────────────────────────────
# LangSmith (Observability & Tracing)
# ─────────────────────────────────────────────────────────────────────────────
# Get your API key from: https://smith.langchain.com
# LangSmith provides tracing, feedback collection, and monitoring

# LANGSMITH_API_KEY=ls__...
# LANGSMITH_PROJECT=langchain-agent
# ENABLE_LANGSMITH_TRACING=false

# Legacy tracing variables (still supported for backward compatibility)
# LANGSMITH_TRACING=true
# LANGCHAIN_TRACING_V2=true

# =============================================================================
# Quick Start Checklist
# =============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in required variables:
#    - GOOGLE_API_KEY (for embeddings)
#    - OPENROUTER_API_KEY (for LLM)
#    - SUPABASE_URL, SUPABASE_KEY, SUPABASE_DIRECT_URL (for vector database)
# 3. Run database migrations: python setupdb.py
# 4. Start the API server: python server.py
# 5. (Local dev only) Start the ingestion pipeline: python cronjob.py
#    In Docker, the container's CMD launches both server.py and cronjob.py
#    automatically — no need to run cronjob.py manually.
# =============================================================================

# ── LLM Provider Selection ──────────────────────────────────────
# Set to "google" or "openai" to choose the active LLM provider
# Default: google
LLM_PROVIDER=google

# ── Google / Gemini API ─────────────────────────────────────────
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Gemini model name (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Gemini temperature (default: 0.7)
GEMINI_TEMPERATURE=0.7

# ── OpenAI API ──────────────────────────────────────────────────
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI model name (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# OpenAI temperature (default: 0.7)
OPENAI_TEMPERATURE=0.7

# ── Supabase / pgvector ─────────────────────────────────────────
# Get your credentials from: https://supabase.com/dashboard
SUPABASE_URL=your-supabase-project-url
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Cron Job Configuration ──────────────────────────────────────
# Interval in minutes for document ingestion cron job
CRON_INTERVAL_MINUTES=5

# ── Knowledge Base Paths ────────────────────────────────────────
KNOWLEDGE_DIR=./knowledge/raw_docs
PROCESSED_DIR=./knowledge/processed
FAILED_DIR=./knowledge/failed

# ── Embedding Configuration ─────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
EMBEDDINGS_BATCH_SIZE=10
EMBEDDING_TIMEOUT=30
EMBEDDING_RETRIES=3

# ── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOGGER_BACKEND=console

# ── LangSmith Tracing ───────────────────────────────────────────
# Set LANGSMITH_TRACING=false to disable tracing entirely.
# Get your API key from: https://smith.langchain.com
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=your-project-name
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── Alerts (Optional) ────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
ALERT_EMAIL=

# ── FastAPI ──────────────────────────────────────────────────────
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_WORKERS=4
